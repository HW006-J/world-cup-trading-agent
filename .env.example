# PitchEdge data source configuration.
#
# Valid values for TXLINE_DATA_SOURCE: "demo" | "txline". Defaults safely to
# "demo" if absent or unrecognized — the app never silently goes "live".
#
# Demo mode (default) needs nothing below and never makes a network request.
TXLINE_DATA_SOURCE=demo

# Only used once TXLINE_DATA_SOURCE=txline. Do not commit a real value.
TXLINE_BASE_URL=https://txline.txodds.com

# Long-lived TxLINE API token obtained out-of-band via the on-chain
# /api/token/activate flow (not implemented here — see README). Required
# whenever TXLINE_DATA_SOURCE=txline; leave empty for demo mode. If
# TXLINE_DATA_SOURCE=txline and this is empty, the app raises a clear
# configuration error rather than pretending to use live data.
#
# Do NOT put a guest JWT here — the live client always requests a fresh one
# from POST /auth/guest/start at runtime.
TXLINE_API_TOKEN=
