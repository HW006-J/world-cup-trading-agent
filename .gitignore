# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python virtual environments
.venv/

# Generated ML files
ml/models/*.joblib
ml/data/processed/next_goal_none.csv
ml/data/processed/statsbomb_next_goal_none.csv
ml/data/processed/next_goal_none_combined.csv

# Downloaded proprietary TxLINE data
ml/data/raw/*
!ml/data/raw/.gitkeep

# Downloaded StatsBomb Open Data (public, but large -- re-downloadable via
# ml/download_statsbomb.py, not committed)
ml/data/external/statsbomb/*
!ml/data/external/statsbomb/.gitkeep
ml/data/external/statsbomb/events/*
!ml/data/external/statsbomb/events/.gitkeep

# Generated download tracker
ml/reports/world_cup_fixture_download_tracker.csv
